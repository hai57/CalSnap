# Backend configuration. Copy to .env and fill in values.

# Database. Defaults to local SQLite. For Postgres use e.g.:
# DATABASE_URL=postgresql+psycopg2://calorie:calorie@localhost:5432/calorie
DATABASE_URL=sqlite:///./calorie.db

# JWT
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# AI provider
# When MOCK_AI=true, the AI service returns canned data and does NOT call any API.
MOCK_AI=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# CORS: comma-separated list of allowed origins for the web app
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Where uploaded images are stored (local dev)
UPLOAD_DIR=./uploads
